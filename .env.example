# ==============================================
# Google Chat Bot 설정 (선택 — 사용하지 않으면 비워두세요)
# ==============================================

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_ACCOUNT_EMAIL=user@example.com

# ==============================================
# Telegram Bot 설정 (선택 — 사용하지 않으면 비워두세요)
# ==============================================

# @BotFather에서 발급받은 토큰
TELEGRAM_BOT_TOKEN=

# 허용할 Telegram 사용자 ID (쉼표 구분, 비어있으면 누구나 사용 가능)
# 봇에게 /myid 명령을 보내면 자신의 ID를 확인할 수 있습니다
TELEGRAM_ALLOWED_USER_IDS=

# ==============================================
# OpenCode 설정
# ==============================================

OPENCODE_SERVER_PORT=4096
OPENCODE_SERVER_PASSWORD=

# ==============================================
# 프로젝트 디렉토리 설정
# 쉼표 구분으로 "별칭:경로" 쌍을 입력
# ==============================================
PROJECTS=admin-laravel:/path/to/workspace/comento-admin-laravel,admin-vue:/path/to/workspace/comento-admin-vue,externship-back:/path/to/workspace/comento-externship-back,externship-front:/path/to/workspace/comento-externship-front,nuxt:/path/to/workspace/comento-nuxt,partners-back:/path/to/workspace/comento-partners-back,dinkisstyle:/path/to/workspace/DINKIssTyle-AI-BBS,laravel:/path/to/workspace/laravel,laravel-style-guide:/path/to/workspace/laravel-style-guide,partner:/path/to/workspace/partner,pathnote2:/path/to/workspace/pathnote2,pyauto:/path/to/workspace/pyauto,pycapture:/path/to/workspace/pycapture,serena:/path/to/workspace/serena,tinkerwell:/path/to/workspace/tinkerwell,z-image-mps:/path/to/workspace/z-image-mps

DEFAULT_PROJECT=admin-laravel

# ==============================================
# 서버 설정
# ==============================================

PORT=8080
CHAT_VERIFICATION_TOKEN=
