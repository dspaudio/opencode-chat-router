# ==============================================
# Google Chat Bot 설정 (선택 — 사용하지 않으면 비워두세요)
# ==============================================

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_ACCOUNT_EMAIL=

# ==============================================
# Telegram Bot 설정 (선택 — 사용하지 않으면 비워두세요)
# ==============================================

# @BotFather에서 발급받은 토큰
TELEGRAM_BOT_TOKEN=

# 허용할 Telegram 사용자 ID (쉼표 구분, 비어있으면 누구나 사용 가능)
# 봇에게 /myid 명령을 보내면 자신의 ID를 확인할 수 있습니다
TELEGRAM_ALLOWED_USER_IDS=

# ==============================================
# OpenCode 설정
# ==============================================

OPENCODE_SERVER_PORT=4096
OPENCODE_SERVER_PASSWORD=

# ==============================================
# 프로젝트 디렉토리 설정
# 쉼표 구분으로 "별칭:경로" 쌍을 입력
# ==============================================
PROJECTS=my-project:/path/to/project,another-project:/path/to/another

DEFAULT_PROJECT=my-project

# ==============================================
# 서버 설정
# ==============================================

PORT=8080
CHAT_VERIFICATION_TOKEN=
